<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                    xmlns:i="clr-namespace:System.Windows.Interactivity;assembly=System.Windows.Interactivity"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    mc:Ignorable="d">

    <Color x:Key="BlackColor">#FF000000</Color>
    <Color x:Key="WhiteColor">#FFFFFFFF</Color>
    <Color x:Key="GlyphColor">#FF004ba4</Color>
    <Color x:Key="GlyphLightColor">#FFFFAA00</Color>
    <Color x:Key="SelectionLightColor">#FF8D919D</Color>
    <Color x:Key="OverlayColor">#BB000000</Color>
    
    <Color x:Key="ControlBackgroundColor">#FF2B354D</Color>
    <Color x:Key="ControlBackgroundColorDark">#FF121830</Color>

    <Color x:Key="TextColor">#FF000000</Color>
    <Color x:Key="TextColorDark">#FF757575</Color>

    <SolidColorBrush x:Key="TextBrush" Color="{DynamicResource TextColor}" />
    <SolidColorBrush x:Key="TextBrushDark" Color="{DynamicResource TextColorDark}" />
    <SolidColorBrush x:Key="GlyphBrush" Color="{DynamicResource GlyphColor}" />
    <SolidColorBrush x:Key="GlyphLightBrush" Color="{DynamicResource GlyphLightColor}" />
    <SolidColorBrush x:Key="ControlBackgroundBrush" Color="{DynamicResource ControlBackgroundColor}" />
    <SolidColorBrush x:Key="ControlBackgroundDarkBrush" Color="{DynamicResource ControlBackgroundColorDark}" />
    <SolidColorBrush x:Key="SelectionLightBrush" Color="{DynamicResource SelectionLightColor}" />
    <SolidColorBrush x:Key="OverlayBrush" Color="{DynamicResource OverlayColor}" />
    <SolidColorBrush x:Key="CheckBoxCheckMarkBkBrush" Color="{DynamicResource ControlBackgroundColorDark}" />

    <sys:Double x:Key="FontSizeSmall">18</sys:Double>
    <sys:Double x:Key="FontSize">22</sys:Double>

    <sys:Double x:Key="FilterPanelWidth">300</sys:Double>
    
    <GridLength x:Key="ProgressWindowWidth">640</GridLength>
    
<Style x:Key="TextBlockBaseStyle" TargetType="TextBlock">
    <Setter Property="FontSize" Value="{DynamicResource FontSize}" />
    <Setter Property="FontFamily" Value="/Fonts/frutiger.ttf#Frutiger" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
</Style>

<LinearGradientBrush x:Key="MainBackgourndBrush" StartPoint="0.5,0" EndPoint="0.5,1">
    <GradientStop Color="#FFacd7ee" Offset="0" />
    <GradientStop Color="#FFffffff" Offset="1.0" />
</LinearGradientBrush>

<LinearGradientBrush x:Key="TopBarBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1">
    <GradientStop Color="#FFf2f6f8" Offset="0.0"/>
    <GradientStop Color="#FFd8e1e7" Offset="0.50"/>
    <GradientStop Color="#FFb5c6d0" Offset="0.51"/>
    <GradientStop Color="#FFe0eff9" Offset="1.0"/>
</LinearGradientBrush>

    <LinearGradientBrush x:Key="BottomBarBackgroundBrush" StartPoint="-0.5,0.5" EndPoint="1.5,1" >
        <GradientStop Color="#FF091F51" Offset="0"/>
        <GradientStop Color="#AA0B1027" Offset="1.0"/>
    </LinearGradientBrush>

  <LinearGradientBrush x:Key="OverlayMenuBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1">
    <GradientStop Color="#FFF0F9FF" Offset="0.0"/>
    <GradientStop Color="#FFCBebFF" Offset="0.47"/>
    <GradientStop Color="#FFA1DBFF" Offset="1.0"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="SelectionBrush" StartPoint="0.5,0" EndPoint="0.5,1">
    <GradientStop Color="#FFFCEABB" Offset="0.0"/>
    <GradientStop Color="#FFFCCD4D" Offset="0.50"/>
    <GradientStop Color="#FFF8B500" Offset="0.51"/>
    <GradientStop Color="#FFFBDF93" Offset="1.0"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="GameDetailsBackgroundBrush" StartPoint="0.5,0" EndPoint="0.5,1">
    <GradientStop Color="#00acd7ee" Offset="0.0"/>
    <GradientStop Color="#FFacd7ee" Offset="0.8"/>
  </LinearGradientBrush>
    
    <SolidColorBrush x:Key="WarningBrush" Color="#ff6b6b" />
</ResourceDictionary>